---
import "../styles/global.css";
import Layout from "../layouts/Layout.astro";
import SustainabilityWidget from "@/components/SustainabilityWidget/SustainabilityWidget";

const handleFormSubmit = (formData: any) => {
    console.log("Sustainability form submitted:", formData);
};
---

<Layout title="Sostenibilidad e Impacto Ambiental | Focalis Stratega Group" description="Dashboard interactivo de sostenibilidad e impacto ambiental. Optimización técnica de recursos y medición digital de huella de carbono.">
    <div
        class="min-h-screen bg-gradient-to-br from-gray-50 via-green-50 to-emerald-50 py-8 px-4"
    >
        <SustainabilityWidget
            client:only="react"
            title="Dashboard de Sostenibilidad e Impacto Verde"
            subtitle="Estrategias sostenibles de ingeniería: optimización hídrica, energética y medición digital de huella de carbono para el cumplimiento de objetivos ESG."
            onFormSubmit={handleFormSubmit}
        />
    </div>
</Layout>
